# um30-spec §"Environment templates". Non-secret values only — the pipeline
# uses these to build the dev Container Apps revision's env var list.
# Secrets (DATABASE_URL, BETTER_AUTH_SECRET, MICROSOFT_CLIENT_SECRET) are
# never listed here; the pipeline adds them as Key Vault secret references
# (see infra/bicep/modules/container-app.bicep). The full, canonical list of
# every env var the app reads — secret and non-secret — lives in the
# repo-root `.env.example` (deviation, codebase wins: that file already
# serves this purpose and is Zod-validated against in `lib/config.ts`; a
# second copy under infra/env/ would drift).
NODE_ENV=production
APP_URL=https://ebill-dev-app.azurecontainerapps.io
BETTER_AUTH_URL=https://ebill-dev-app.azurecontainerapps.io
NEXT_PUBLIC_APP_URL=https://ebill-dev-app.azurecontainerapps.io
LOG_LEVEL=info
ENTRA_TENANT_ID=
MICROSOFT_CLIENT_ID=
