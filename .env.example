# um01/um02/um03 env surface — see lib/config.ts. Entra/Key Vault keys are added by the units that need them.
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=info
# Production DATABASE_URL is sourced from Key Vault via Managed Identity (um25).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_billing

# Better-Auth config (um03). Production BETTER_AUTH_SECRET is sourced from
# Key Vault via Managed Identity (um25); generate a local value with
# `openssl rand -base64 32`.
BETTER_AUTH_SECRET=replace-with-a-random-32-character-or-longer-secret
BETTER_AUTH_URL=http://localhost:3000
# Client-safe public base URL used by auth/client.ts — the only NEXT_PUBLIC_
# variable introduced in um03; non-secret.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Seeded break-glass LOCAL admin (um03). BOOTSTRAP_ADMIN_PASSWORD is used once
# at seed time to generate a scrypt hash stored in the DB; it can be removed
# from .env after the first `npm run db:seed`. Production sources it from Key
# Vault via Managed Identity (um25).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password-16+chars

# Entra SSO (um10) — optional. Omit any of the three to disable SSO entirely
# (the Microsoft provider is not registered and the "Sign in with Microsoft"
# button is hidden); local sign-in is unaffected either way. Production
# MICROSOFT_CLIENT_SECRET is sourced from Key Vault via Managed Identity
# (um25) — never paste it into a deployed environment's .env file.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
ENTRA_TENANT_ID=

# LOCAL password policy (um25) — all optional, enforced defaults below apply
# when absent. Requires a redeploy to change; not editable via the
# Configuration Parameters UI. Applied uniformly to first-login password
# changes, admin password resets, and temp password generation.
PASSWORD_MIN_LENGTH=15
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
# Allowed special character set for both validation and generation. Quoted
# because Next.js's bundled dotenv treats an unquoted value's `#` as the
# start of an inline comment, which would otherwise truncate this value.
PASSWORD_SPECIAL_CHARS="!@#$%^&*()_+-=[]{}|;':\",./<>?"
